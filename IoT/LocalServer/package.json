{
  "name": "iot-local-server",
  "version": "0.1.0",
  "description": "ESP32ローカル管理サーバー（Web UI/MQTT/OTA配布）",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:connect": "tsx src/tools/testConnection.ts",
    "test:7064": "node scripts/test7064PasswordChange.mjs",
    "test:7040": "node scripts/test7040KeyRotationE2E.mjs",
    "test:7041": "node scripts/test7041ProductionDryRunE2E.mjs",
    "test:7041:preflight": "node scripts/test7041ProductionDryRunE2E.mjs --preflightOnly",
    "test:7041:preflight:wait": "node scripts/test7041ProductionDryRunE2E.mjs --preflightOnly --preflightRetryCount 30 --preflightRetryIntervalMs 2000",
    "test:7041:summary": "node scripts/test7041ReportSummary.mjs --count 2",
    "test:7041:pipeline": "node scripts/test7041Pipeline.mjs",
    "test:7041:pipeline:wait": "node scripts/test7041Pipeline.mjs --preflightRetryCount 30 --preflightRetryIntervalMs 2000 --summaryCount 2",
    "test:7041:pipeline:auto-diag": "node scripts/test7041Pipeline.mjs --autoDiagOnPreflightFail",
    "test:7041:pipeline:strict": "node scripts/test7041Pipeline.mjs --strictGate",
    "test:7041:gate": "node scripts/test7041GateCheck.mjs",
    "test:7041:gate:strict": "node scripts/test7041GateCheck.mjs --strict",
    "test:7041:diag": "powershell -ExecutionPolicy Bypass -File .\\scripts\\collect7041ApConnectivityDiagnostics.ps1",
    "test:7081": "node scripts/test7081BasicStability.mjs",
    "test:7082": "node scripts/test7082SecuredE2E.mjs",
    "keys:vault:setup": "node scripts/setupKiotKeyVault.mjs",
    "keys:vault:unlock": "node scripts/unlockKiotKeyVault.mjs",
    "test:7087": "node scripts/unlockKiotKeyVault.mjs && node scripts/test7087ProductionToolSmoke.mjs",
    "test:7087:normal": "node scripts/unlockKiotKeyVault.mjs && node scripts/test7087ProductionToolSmokeNormal.mjs",
    "test:7083": "node scripts/test7083OtaDurability.mjs",
    "test:7084": "node scripts/test7084OneHourLoad.mjs",
    "test:8001": "node scripts/test8001MqttAuthFailure.mjs"
  },
  "keywords": [
    "iot",
    "esp32",
    "mqtt",
    "ota",
    "typescript"
  ],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mqtt": "^5.14.1",
    "multer": "^2.1.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
